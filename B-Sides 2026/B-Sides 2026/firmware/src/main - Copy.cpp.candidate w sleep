#include <Arduino.h>
#include <Adafruit_NeoPixel.h>
#include <ptc.h>
#include <avr/sleep.h>
#include <avr/interrupt.h>

#define PIEZO_PIN   PIN_PA1
#define TOUCH_PIN   PIN_PA4
#define LED_DATA    PIN_PB4
#define LED_PWR_EN  PIN_PB5
#define NUM_LEDS    4

Adafruit_NeoPixel strip(NUM_LEDS, LED_DATA, NEO_GRB + NEO_KHZ800);
cap_sensor_t touch_node;

// --- THE SHADOW CLOCK VARIABLES ---
volatile uint32_t sleepTicks = 0; 

// The PIT Interrupt Service Routine (Wakes the chip up every 31ms)
ISR(RTC_PIT_vect) {
  RTC.PITINTFLAGS = RTC_PI_bm; // Clear the interrupt flag
  sleepTicks += 31;            // Add 31 milliseconds to our shadow clock
}

// Our custom replacement for millis() that works through deep sleep
uint32_t getCustomMillis() {
  uint32_t ms;
  cli(); // Briefly disable interrupts to safely read the variable
  ms = millis() + sleepTicks;
  sei(); // Re-enable interrupts
  return ms;
}

// --- STATE VARIABLES ---
volatile bool rawTouched = false; 
bool cleanTouchState = false; 
uint32_t lastDebounceTime = 0; 
const uint32_t debounceDelay = 50; 
uint32_t lastInteractionTime = 0; 

void setLedPower(bool on) {
  if (on) {
    pinMode(LED_PWR_EN, OUTPUT);
    digitalWrite(LED_PWR_EN, LOW); 
    delay(20); 
  } else {
    digitalWrite(LED_PWR_EN, HIGH);
    pinMode(LED_DATA, OUTPUT); 
    digitalWrite(LED_DATA, LOW);
  }
}

void safeTone(int freq, int duration_ms) {
  uint32_t halfPeriodUs = 1000000UL / freq / 2;
  uint32_t numCycles = ((uint32_t)freq * duration_ms) / 1000;
  for (uint32_t k = 0; k < numCycles; k++) {
    digitalWrite(PIEZO_PIN, HIGH);
    delayMicroseconds(halfPeriodUs);
    digitalWrite(PIEZO_PIN, LOW);
    delayMicroseconds(halfPeriodUs);
  }
}

void playStarTrekChirp() {
  setLedPower(true);
  
  for (int j = 0; j < 2; j++) {
    int startFreq = (j == 0) ? 800 : 1000;
    
    for (int i = 0; i < 20; i++) {
      int freq = startFreq + (i * 20);
      safeTone(freq, 3); 
      ptc_process(getCustomMillis()); 
    }
    
    digitalWrite(PIEZO_PIN, LOW); 
    
    for(int l = 0; l < NUM_LEDS; l++) {
      strip.setPixelColor(l, strip.Color(0, 15, 15)); 
    }
    strip.show();
    
    uint32_t waitStart = getCustomMillis();
    while(getCustomMillis() - waitStart < 20) { ptc_process(getCustomMillis()); } 
    
    strip.clear();
    strip.show();
    
    if (j == 0) {
       waitStart = getCustomMillis();
       while(getCustomMillis() - waitStart < 40) { ptc_process(getCustomMillis()); }
    }
  }

  strip.clear();
  strip.show();
  uint32_t waitStart = getCustomMillis();
  while(getCustomMillis() - waitStart < 5) { ptc_process(getCustomMillis()); }
  
  setLedPower(false);
}

void ptc_event_cb_touch(const ptc_cb_event_t eventType, cap_sensor_t *node) {
  if (PTC_CB_EVENT_TOUCH_DETECT == eventType) {
    rawTouched = true;
  } else if (PTC_CB_EVENT_TOUCH_RELEASE == eventType) {
    rawTouched = false;
  }
}

void ptc_event_cb_calibration(const ptc_cb_event_t eventType, cap_sensor_t* node) {
  if (eventType == PTC_CB_EVENT_ERR_CALIB_LOW || eventType == PTC_CB_EVENT_ERR_CALIB_HIGH) {
    _PROTECTED_WRITE(RSTCTRL.SWRR, RSTCTRL_SWRE_bm); 
  }
  rawTouched = false;
}

void setup() {
  pinMode(PIEZO_PIN, OUTPUT);
  digitalWrite(PIEZO_PIN, LOW);

  ptc_add_selfcap_node(&touch_node, 0, PIN_TO_PTC(TOUCH_PIN));
  ptc_node_set_thresholds(&touch_node, 15, 10); 

  // --- LOW POWER HARDWARE CONFIGURATION ---
  // 1. Disable the Brown-Out Detector during sleep
  _PROTECTED_WRITE(BOD.CTRLA, BOD_SLEEP_DIS_gc);

  // 2. Configure the RTC Timer to use the internal 32.768 kHz oscillator
  while (RTC.STATUS > 0); 
  RTC.CLKSEL = RTC_CLKSEL_INT32K_gc;
  
  // 3. Set the PIT to wake the chip every ~31ms (1024 cycles)
  RTC.PITCTRLA = RTC_PERIOD_CYC1024_gc | RTC_PITEN_bm;
  RTC.PITINTCTRL = RTC_PI_bm; // Enable PIT interrupts

  // 4. Arm the Standby Sleep Mode
  SLPCTRL.CTRLA = SLEEP_MODE_STANDBY | SLPCTRL_SEN_bm;

  setLedPower(true);
  strip.begin();
  strip.clear();
  
  // Purple Boot Phase
  for(int i=0; i<NUM_LEDS; i++) strip.setPixelColor(i, strip.Color(10, 0, 10)); 
  strip.show();

  uint32_t start_time = getCustomMillis();
  while (getCustomMillis() - start_time < 1000) {
      ptc_process(getCustomMillis());
  }

  strip.clear();
  strip.show();
  setLedPower(false);

  lastInteractionTime = getCustomMillis(); 
}

void loop() {
  // Feed the touch library with our custom shadow clock
  ptc_process(getCustomMillis());

  // --- SOFTWARE DEBOUNCE LOGIC ---
  if (rawTouched != cleanTouchState) {
    if ((getCustomMillis() - lastDebounceTime) > debounceDelay) {
      cleanTouchState = rawTouched; 
      lastInteractionTime = getCustomMillis(); 

      if (cleanTouchState) {
        playStarTrekChirp(); 
      }
    }
  } else {
    lastDebounceTime = getCustomMillis();
  }

  // --- THE SELF-HEALING STATE MACHINE ---
  if (cleanTouchState) {
    if (getCustomMillis() - lastInteractionTime > 2000) {
      setLedPower(true);
      for(int i=0; i<NUM_LEDS; i++) strip.setPixelColor(i, strip.Color(10, 5, 0)); 
      strip.show();
      delay(500); 
      _PROTECTED_WRITE(RSTCTRL.SWRR, RSTCTRL_SWRE_bm); 
    }
  } else {
    if (getCustomMillis() - lastInteractionTime > 30000) {
      _PROTECTED_WRITE(RSTCTRL.SWRR, RSTCTRL_SWRE_bm); 
    }
  }

  // --- THE SLEEP TRIGGER ---
  // Instantly pause the processor here. 
  // It will wake up in ~31ms when the RTC kicks it, and resume from the top of the loop.
  sleep_cpu(); 
}
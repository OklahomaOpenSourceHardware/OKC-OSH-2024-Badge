#include <Arduino.h>
#include <Adafruit_NeoPixel.h>
#include <avr/sleep.h>
#include <avr/io.h>
#include <ptc.h>

//#define ENABLE_LOW_POWER

#define PIEZO_PIN   PIN_PA1
#define TOUCH_PIN   PIN_PA4
#define LED_DATA    PIN_PB4
#define LED_PWR_EN  PIN_PB5
#define SDA_SAO     PIN_PB2
#define SCL_SAO     PIN_PB3
#define PC3_SAO     PIN_PC3
#define NUM_LEDS    4

Adafruit_NeoPixel strip(NUM_LEDS, LED_DATA, NEO_GRB + NEO_KHZ800);

uint32_t nextSleep = 10000;
cap_sensor_t touch_node;

// --- DEBOUNCE VARIABLES ---
volatile bool rawTouched = false;
bool cleanTouchState = false;
uint32_t lastDebounceTime = 0;
const uint32_t debounceDelay = 50; // Require 50ms of stable signal to confirm a touch

uint32_t lastTouchTime = 0; 

long readVcc() {
  return 3300; 
}

void setLedPower(bool on) {
  if (on) {
    pinMode(LED_PWR_EN, OUTPUT);
    digitalWrite(LED_PWR_EN, LOW); 
    delay(20); 
  } else {
    digitalWrite(LED_PWR_EN, HIGH);
    pinMode(LED_DATA, OUTPUT); 
    digitalWrite(LED_DATA, LOW);
  }
}

// --- ANTI-FREEZE FIX 1: Safe Tone Generator ---
// Bypasses the hardware timer to prevent crashing the PTC library
void safeTone(int freq, int duration_ms) {
  uint32_t halfPeriodUs = 1000000UL / freq / 2;
  uint32_t numCycles = ((uint32_t)freq * duration_ms) / 1000;
  for (uint32_t k = 0; k < numCycles; k++) {
    digitalWrite(PIEZO_PIN, HIGH);
    delayMicroseconds(halfPeriodUs);
    digitalWrite(PIEZO_PIN, LOW);
    delayMicroseconds(halfPeriodUs);
  }
}

void playStarTrekChirp() {
  setLedPower(true);
  
  for (int j = 0; j < 2; j++) {
    int startFreq = (j == 0) ? 800 : 1000;
    
    // --- PHASE 1: AUDIO ONLY ---
    for (int i = 0; i < 20; i++) {
      int freq = startFreq + (i * 20);
      safeTone(freq, 3); // Swapped standard tone() for safeTone()
      ptc_process(millis()); // ANTI-FREEZE FIX 2: Keep PTC alive during loop
    }
    
    digitalWrite(PIEZO_PIN, LOW); 
    
    // --- PHASE 2: VISUAL ONLY ---
    for(int l = 0; l < NUM_LEDS; l++) {
      strip.setPixelColor(l, strip.Color(0, 15, 15));
    }
    strip.show();
    
    // Keep PTC alive while holding the light for 20ms
    uint32_t waitStart = millis();
    while(millis() - waitStart < 20) { ptc_process(millis()); } 
    
    strip.clear();
    strip.show();
    
    if (j == 0) {
       waitStart = millis();
       while(millis() - waitStart < 40) { ptc_process(millis()); }
    }
  }

  strip.clear();
  strip.show();
  uint32_t waitStart = millis();
  while(millis() - waitStart < 5) { ptc_process(millis()); }
  
  setLedPower(false);
}

void ptc_event_cb_touch(const ptc_cb_event_t eventType, cap_sensor_t *node) {
  // Update the raw state instantly, let the main loop debounce it
  if (PTC_CB_EVENT_TOUCH_DETECT == eventType) {
    rawTouched = true;
  } else if (PTC_CB_EVENT_TOUCH_RELEASE == eventType) {
    rawTouched = false;
  }
}

void ptc_event_cb_calibration(const ptc_cb_event_t eventType, cap_sensor_t* node)  {
  // Reset raw state on a calibration error to prevent sticking
  rawTouched = false;
}

void setup() {
  ptc_add_selfcap_node(&touch_node, 0, PIN_TO_PTC(TOUCH_PIN));

  uint32_t start_time = millis();
  while (millis() - start_time < 1000) {
      ptc_process(millis());
  }

  strip.begin();
  strip.clear();
  strip.show();

#ifdef ENABLE_LOW_POWER
  _PROTECTED_WRITE(BOD.CTRLA, BOD_SLEEP_DIS_gc);
  RTC.CLKSEL = RTC_CLKSEL_INT32K_gc;
  while (RTC.STATUS > 0); 
  RTC.PITCTRLA = RTC_PERIOD_CYC4096_gc | RTC_PITEN_bm;
  EVSYS.ASYNCCH3 = EVSYS_ASYNCCH3_PIT_DIV4096_gc;
  EVSYS.ASYNCUSER0 = EVSYS_ASYNCUSER0_ASYNCCH3_gc; // Corrected routing to PTC
  SLPCTRL.CTRLA = SLEEP_MODE_STANDBY | SLPCTRL_SEN_bm;
#endif

  pinMode(LED_PWR_EN, OUTPUT);
  setLedPower(false);
  pinMode(PIEZO_PIN, OUTPUT);
  digitalWrite(PIEZO_PIN, LOW);
}

void loop() {
  ptc_process(millis());    

  // --- SOFTWARE DEBOUNCE LOGIC ---
  if (rawTouched != cleanTouchState) {
    // If the state has been stable for 50ms...
    if ((millis() - lastDebounceTime) > debounceDelay) {
      cleanTouchState = rawTouched; 
      
      // ...and it's a "press" (not a release)
      if (cleanTouchState) {
        // ...and the cooldown timer has expired
        if (millis() - lastTouchTime > 1000) {
          playStarTrekChirp();   
          lastTouchTime = millis(); 
        }
      }
    }
  } else {
    // Reset the debounce timer if the state matches (filters out noise)
    lastDebounceTime = millis();
  }

#ifdef ENABLE_LOW_POWER
  set_sleep_mode(SLEEP_MODE_STANDBY);
  sleep_enable();
  sleep_cpu();
  sleep_disable();
#else
  delay(10);
#endif
}
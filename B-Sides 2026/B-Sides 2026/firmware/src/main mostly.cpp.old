//works and flashes leds, and beeps but freezes after one press

#include <Arduino.h>
#include <Adafruit_NeoPixel.h>
#include <avr/sleep.h>
#include <avr/io.h>
#include <ptc.h>

//#define ENABLE_LOW_POWER

#define PIEZO_PIN   PIN_PA1
#define TOUCH_PIN   PIN_PA4
#define LED_DATA    PIN_PB4
#define LED_PWR_EN  PIN_PB5
#define SDA_SAO     PIN_PB2
#define SCL_SAO     PIN_PB3
#define PC3_SAO     PIN_PC3
#define NUM_LEDS    4

// --- REVERTED to standard GRB ---
Adafruit_NeoPixel strip(NUM_LEDS, LED_DATA, NEO_GRB + NEO_KHZ800);

uint32_t nextSleep = 10000;
cap_sensor_t touch_node;
volatile bool touchDetected = false;

// Cooldown tracker to prevent crashing the PTC library
uint32_t lastTouchTime = 0; 

long readVcc() {
  return 3300; 
}

void setLedPower(bool on) {
  if (on) {
    pinMode(LED_PWR_EN, OUTPUT);
    digitalWrite(LED_PWR_EN, LOW); 
    delay(20); 
    // Notice strip.begin() is removed from here. It belongs in setup().
  } else {
    digitalWrite(LED_PWR_EN, HIGH);
    pinMode(LED_DATA, OUTPUT); 
    digitalWrite(LED_DATA, LOW);
  }
}

void playStarTrekChirp() {
  setLedPower(true);
  
  for (int j = 0; j < 2; j++) {
    int startFreq = (j == 0) ? 800 : 1000;
    
    // --- PHASE 1: AUDIO ONLY (LEDs are OFF) ---
    for (int i = 0; i < 20; i++) {
      int freq = startFreq + (i * 20);
      tone(PIEZO_PIN, freq);
      delay(3); // Slightly shorter delay
    }
    
    // CRITICAL: Completely kill the audio power before touching LEDs
    noTone(PIEZO_PIN);
    digitalWrite(PIEZO_PIN, LOW); 
    
    // --- PHASE 2: VISUAL ONLY (Audio is OFF) ---
    for(int l = 0; l < NUM_LEDS; l++) {
      // Very brief, low-power cyan flash
      strip.setPixelColor(l, strip.Color(0, 15, 15));
    }
    strip.show();
    
    // Hold the light for 20ms so the eye registers it
    delay(20); 
    
    // Turn LEDs off before the next loop starts
    strip.clear();
    strip.show();
    
    // Pause between the two chirps
    if (j == 0) delay(40);
  }

  // Final cleanup before sleep
  strip.clear();
  strip.show();
  delay(5); 
  
  setLedPower(false);
}

void ptc_event_cb_touch(const ptc_cb_event_t eventType, cap_sensor_t *node) {
  if (PTC_CB_EVENT_TOUCH_DETECT == eventType) {
    touchDetected = true;
  } 
}

void ptc_event_cb_calibration(const ptc_cb_event_t eventType, cap_sensor_t* node)  {
  // Silently ignore
}

void setup() {
  ptc_add_selfcap_node(&touch_node, 0, PIN_TO_PTC(TOUCH_PIN));

  uint32_t start_time = millis();
  while (millis() - start_time < 1000) {
      ptc_process(millis());
  }

  // --- MOVED: Initialize NeoPixels once ---
  strip.begin();
  strip.clear();
  strip.show();

#ifdef ENABLE_LOW_POWER
  _PROTECTED_WRITE(BOD.CTRLA, BOD_SLEEP_DIS_gc);
  RTC.CLKSEL = RTC_CLKSEL_INT32K_gc;
  while (RTC.STATUS > 0); 
  RTC.PITCTRLA = RTC_PERIOD_CYC4096_gc | RTC_PITEN_bm;
  EVSYS.ASYNCCH3 = EVSYS_ASYNCCH3_PIT_DIV4096_gc;
  EVSYS.ASYNCUSER1 = EVSYS_ASYNCUSER1_ASYNCCH3_gc;
  SLPCTRL.CTRLA = SLEEP_MODE_STANDBY | SLPCTRL_SEN_bm;
#endif

  pinMode(LED_PWR_EN, OUTPUT);
  setLedPower(false);
  pinMode(PIEZO_PIN, OUTPUT);
  digitalWrite(PIEZO_PIN, LOW);
}

void loop() {
  ptc_process(millis());    

  if (touchDetected) {
    touchDetected = false; 
    
    // --- NEW: Cooldown Logic ---
    // Only play if it's been at least 1000ms (1 second) since the last touch
    if (millis() - lastTouchTime > 1000) {
      playStarTrekChirp();   
      lastTouchTime = millis(); // Reset the cooldown timer
    }
  }

#ifdef ENABLE_LOW_POWER
  set_sleep_mode(SLEEP_MODE_STANDBY);
  sleep_enable();
  sleep_cpu();
  sleep_disable();
#else
  delay(10);
#endif
}